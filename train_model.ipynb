   "source": [
    "ocp_col_names = ocp_onehot_encoder.get_feature_names_out(['ocean_proximity'])\n",
    "\n",
    "ocp_cols_train = X_train[ocp_col_names]\n",
    "ocp_cols_val = X_val[ocp_col_names]\n",
    "ocp_cols_test = X_test[ocp_col_names]\n",
    "\n",
    "normal_col_names = [\n",
    "    \"longitude\",\n",
    "    \"latitude\",\n",
    "    \"housing_median_age\",\n",
    "    \"median_income\"\n",
    "]\n",
    "\n",
    "skew_col_names = [\n",
    "    \"total_rooms\",\n",
    "    \"total_bedrooms\",\n",
    "    \"population\",\n",
    "    \"households\"\n",
    "]\n",
    "\n",
    "X_standard_scaler = StandardScaler()\n",
    "X_robust_scaler = RobustScaler()\n",
    "Y_standard_scaler = StandardScaler()\n",
    "\n",
    "data_preprocessor = ColumnTransformer([\n",
    "    (\"standard\", X_standard_scaler, normal_col_names),\n",
    "    (\"robust\", X_robust_scaler, skew_col_names),\n",
    "])\n",
    "\n",
    "X_train_cols_rest = pd.DataFrame(     # DataFrame (-1, 8)\n",
    "    data_preprocessor.fit_transform(X_train.drop(columns=ocp_col_names)),  # fit vГ  transform\n",
    "    columns=X_train.drop(columns=ocp_col_names).columns,\n",
    "    index=X_train.index\n",
    ")\n",
    "\n",
    "X_val_cols_rest = pd.DataFrame(\n",
    "    data_preprocessor.transform(X_val.drop(columns=ocp_col_names)),  # transform\n",
    "    columns=X_val.drop(columns=ocp_col_names).columns,\n",
    "    index=X_val.index\n",
    ")\n",
    "\n",
    "X_test_cols_rest = pd.DataFrame(\n",
    "    data_preprocessor.transform(X_test.drop(columns=ocp_col_names)),\n",
    "    columns=X_test.drop(columns=ocp_col_names).columns,\n",
    "    index=X_test.index\n",
    ")\n",
    "\n",
    "X_train = pd.concat([X_train_cols_rest, ocp_cols_train], axis=1) # DataFrame (-1, 13)\n",
    "X_val = pd.concat([X_val_cols_rest, ocp_cols_val], axis=1)\n",
    "X_test = pd.concat([X_test_cols_rest, ocp_cols_test], axis=1)\n",
    "\n",
    "Y_train = pd.DataFrame(\n",
    "    Y_standard_scaler.fit_transform(Y_train),\n",
    "    columns=Y_train.columns,\n",
    "    index=Y_train.index\n",
    ")\n",
    "\n",
    "Y_val = pd.DataFrame(\n",
    "    Y_standard_scaler.transform(Y_val),\n",
    "    columns=Y_val.columns,\n",
    "    index=Y_val.index\n",
    ")\n",
    "\n",
    "Y_test = pd.DataFrame(\n",
    "    Y_standard_scaler.transform(Y_test),\n",
    "    columns=Y_test.columns,\n",
    "    index=Y_test.index\n",
    ")\n",
    "\n",
    "X_train"
   ]
  },
