      "source": [
        "ocp_names = [\"ocean_proximity_<1h ocean\", \"ocean_proximity_inland\", \"ocean_proximity_island\", \"ocean_proximity_near bay\", \"ocean_proximity_near ocean\"]\n",
        "\n",
        "ocp_cols_train = X_train[ocp_names]\n",
        "ocp_cols_val = X_val[ocp_names]\n",
        "ocp_cols_test = X_test[ocp_names]\n",
        "\n",
        "skew_col_names = [\n",
        "    \"total_rooms\",\n",
        "    \"total_bedrooms\",\n",
        "    \"population\",\n",
        "    \"households\"\n",
        "]\n",
        "\n",
        "normal_col_names = [\n",
        "    \"longitude\",\n",
        "    \"latitude\",\n",
        "    \"housing_median_age\",\n",
        "    \"median_income\"\n",
        "]\n",
        "\n",
        "X_robust_scaler = RobustScaler()\n",
        "X_standard_scaler = StandardScaler()\n",
        "Y_standard_scaler = StandardScaler()\n",
        "\n",
        "data_preprocessor = ColumnTransformer([\n",
        "    (\"robust\", X_robust_scaler, [\n",
        "        skew_col_names\n",
        "    ]),\n",
        "\n",
        "    (\"standard\", X_standard_scaler, [\n",
        "        normal_col_names\n",
        "    ])\n",
        "])\n",
        "\n",
        "X_train = pd.DataFrame(\n",
        "    data_preprocessor.fit_transform(X_train),  # fit vГ  transform\n",
        "    columns=X_train.drop(columns=ocp_names).columns,\n",
        "    index=X_train.index\n",
        ")\n",
        "\n",
        "X_val = pd.DataFrame(\n",
        "    data_preprocessor.transform(X_val),  # transform\n",
        "    columns=X_val.drop(columns=ocp_names).columns,\n",
        "    index=X_val.index\n",
        ")\n",
        "\n",
        "X_test = pd.DataFrame(\n",
        "    data_preprocessor.transform(X_test),  # transform\n",
        "    columns=X_test.drop(columns=ocp_names).columns,\n",
        "    index=X_test.index\n",
        ")\n",
        "\n",
        "X_train = pd.concat([X_train, ocp_cols_train], axis=1) # DataFrame (-1, 13)\n",
        "X_val = pd.concat([X_val, ocp_cols_val], axis=1)\n",
        "X_test = pd.concat([X_test, ocp_cols_test], axis=1)\n",
        "\n",
        "Y_train = pd.DataFrame(\n",
        "    Y_standard_scaler.fit_transform(Y_train),\n",
        "    columns=Y_train.columns,\n",
        "    index=Y_train.index\n",
        ")\n",
        "\n",
        "Y_val = pd.DataFrame(\n",
        "    Y_standard_scaler.transform(Y_val),\n",
        "    columns=Y_val.columns,\n",
        "    index=Y_val.index\n",
        ")\n",
        "\n",
        "Y_test = pd.DataFrame(\n",
        "    Y_standard_scaler.transform(Y_test),\n",
        "    columns=Y_test.columns,\n",
        "    index=Y_test.index\n",
        ")\n",
        "\n",
        "X_train"
      ]
    },
